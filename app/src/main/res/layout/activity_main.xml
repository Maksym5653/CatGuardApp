<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- Logo / Title -->
    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🐱 CatGuard"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVerticalChainStyle="packed"
        android:layout_marginTop="80dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart Security Camera"
        android:textColor="#80FFFFFF"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/tvLogo"
        app:layout_constraintBottom_toTopOf="@+id/btnCameraMode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="64dp" />

    <!-- Camera Mode Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCameraMode"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:text="📷\nCamera Mode\nTransmit &amp; Detect"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        app:backgroundTint="#1A6B3C"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitle"
        app:layout_constraintBottom_toTopOf="@+id/btnViewerMode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="24dp" />

    <!-- Viewer Mode Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewerMode"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:text="🖥️\nViewer Mode\nMonitor &amp; Alarm"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        app:backgroundTint="#1A3D6B"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@+id/btnCameraMode"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="80dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
